local CachedGoals = {}
local function RefreshHoops()
    table.clear(CachedGoals)
    for _, Obj in pairs(workspace:GetDescendants()) do
        if Obj:IsA("BasePart") and Obj.Name == "SHEESH" then table.insert(CachedGoals, Obj) end
    end
end
