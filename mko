-- [[ SOUL ORIGINAL LOGIC ]] --
local function pow()
    local pLabel = player.PlayerGui:FindFirstChild("Power") and player.PlayerGui.Power.PowerFrame.Power
    return pLabel and tonumber(pLabel.Text) or 85
end

local function getGoal()
    local char = player.Character
    if not char or not char:FindFirstChild("Torso") then return nil, nil end
    local torsoPos = char.Torso.Position
    local dist, goal = math.huge, nil
    for _, v in ipairs(CachedGoals) do
        if v and v.Parent then
            local mag = (torsoPos - v.Position).Magnitude
            if mag < dist then dist, goal = mag, v end
        end
    end
    return dist, goal
end

local function arc()
    local dist, goal = getGoal()
    if not dist then return 65 end
    local power = pow()
    dist = math.floor(dist)
    if power == 85 then
        if dist == 59 then return 80 elseif dist == 60 then return 78 elseif dist == 61 then return 77
        elseif dist == 62 then return 75 elseif dist == 63 then return 73 elseif dist == 64 then return 70
        elseif dist == 65 then return 68 elseif dist == 66 then return 65 elseif dist == 67 then return 63
        elseif dist == 68 then return 55 elseif dist == 69 then return 53 elseif dist == 70 then return 51
        elseif dist == 71 then return 46 end
    elseif power == 80 then
        if dist == 55 then return 70 elseif dist == 56 then return 68 elseif dist == 57 then return 66
        elseif dist == 58 then return 64 elseif dist == 59 then return 62 elseif dist == 60 then return 60
        elseif dist == 61 then return 58 elseif dist == 62 then return 56 elseif dist == 63 then return 54
        elseif dist == 64 then return 52 elseif dist == 65 then return 50 elseif dist == 66 then return 48 end
    end
    return 65
end

local function GetKey()
    for _, v in pairs(getgc(true)) do
        if typeof(v) == "function" and debug.getinfo(v).name == "shoot" then
            for _, up in pairs(debug.getupvalues(v)) do
                if typeof(up) == "string" and #up > 10 then return up end
            end
        end
    end
    return ""
end

local function Shoot()
    local dist, goal = getGoal()
    local ArcVal = arc()
    if not goal then return end
    local Vector = goal.Position + Vector3.new(0, ArcVal, 0)
    local char = player.Character
    if char and char:FindFirstChild("Head") then
        local Unit = (Vector - char.Head.Position).Unit
        local SpawnPosition = char.PrimaryPart.Position + Unit * 3.8
        ShootRemote:FireServer(Vector, SpawnPosition, GetKey())
    end
end

