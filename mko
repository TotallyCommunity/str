-- Universal Long Arm & Shot Magnet
local ReachPart = Instance.new("Part")
ReachPart.Transparency = 1
ReachPart.CanCollide = false
ReachPart.Anchored = false
ReachPart.Name = "UniversalReachPart"

RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end

    if getgenv().ReachEnabled then
        local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
        if hand then
            ReachPart.Parent = char
            ReachPart.Size = Vector3.new(getgenv().ReachSize, getgenv().ReachSize, getgenv().ReachSize)
            ReachPart.CFrame = hand.CFrame
        end
    else
        ReachPart.Parent = nil
    end

    if getgenv().MagnetEnabled then
        local ball = workspace:FindFirstChild("Basketball")
        if ball and ball:IsA("BasePart") and not ball:FindFirstChild("PlayerWeld") then
            if (char.HumanoidRootPart.Position - ball.Position).Magnitude < 15 then
                ball.Velocity = (char.HumanoidRootPart.Position - ball.Position).Unit * 35
            end
        end
    end

    if getgenv().ShotMagnet then
        local ball = workspace:FindFirstChild("Basketball")
        if ball and ball:IsA("BasePart") and not ball:FindFirstChild("PlayerWeld") then
            if ball.Velocity.Magnitude > 20 then
                ball.CFrame = ball.CFrame:Lerp(char.HumanoidRootPart.CFrame, 0.2)
            end
        end
    end
end)

-- Predictive Auto Guard Logic (Your Code)
task.spawn(function()
    while true do
        task.wait()
        if getgenv().GuardEnabled then
            for i, v in pairs(Players:GetPlayers()) do
                local char = player.Character
                if v ~= player and v.Character and v.Character:FindFirstChild("Torso") and char and char:FindFirstChild("Torso") then
                    if (v.Character.Torso.Position - char.Torso.Position).Magnitude < 25 then
                        if v.Character.Torso.Velocity.Magnitude > 0.5 and v.Character:FindFirstChild("Basketball") then
                            char.Humanoid:MoveTo(v.Character.Torso.Position + v.Character.Torso.Velocity.unit * 7)
                        elseif v.Character.Torso.Velocity.Magnitude < 0.5 and v.Character:FindFirstChild("Basketball") then
                            char.Humanoid:MoveTo(v.Character.Torso.Position)
                        end
                    end
                end
            end
        end
    end
end)

-- Jump Lock Logic
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")

    if getgenv().CamLockEnabled and char:FindFirstChild("Basketball") and hum then
        local state = hum:GetState()
        if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
            local _, goal = getGoal()
            if goal then
                local targetPos = goal.Position + Vector3.new(0, arc(), 0)
                local lookAt = CFrame.new(Camera.CFrame.Position, targetPos)
                Camera.CFrame = Camera.CFrame:Lerp(lookAt, 1 - getgenv().Smoothness)
            end
        end
    end
end)

-- Keybinds
UserInputService.InputBegan:Connect(function(Key, GPE)
    if GPE then return end
    if Key.KeyCode == Enum.KeyCode.B and player.Character:FindFirstChild("Basketball") then
        player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait(0.28)
        Shoot()
    elseif Key.KeyCode == Enum.KeyCode.G then
        getgenv().CamLockEnabled = not getgenv().CamLockEnabled
        JToggle:Set(getgenv().CamLockEnabled)
    elseif Key.KeyCode == Enum.KeyCode.C then
        getgenv().GuardEnabled = not getgenv().GuardEnabled
        GToggle:Set(getgenv().GuardEnabled)
    end
end)

